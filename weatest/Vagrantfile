Vagrant.configure("2") do |config|
  config.vm.box = "generic/ubuntu2204"

  config.vm.hostname = "weatest"

  # Network — uncomment to expose a port to the host
  # config.vm.network "forwarded_port", guest: 8080, host: 8080

  # Provider: Linux (libvirt)
  config.vm.provider :libvirt do |lv|
    lv.memory               = 6144
    lv.cpus                 = 4
    lv.graphics_type        = "spice"
    lv.video_type           = "qxl"
    lv.video_vram           = 65536  # KB — 64MB
    lv.machine_virtual_size = 40     # GB
  end

  # Provider: macOS (VMware Fusion / Workstation Pro)
  # VAGRANT_DEFAULT_PROVIDER=vmware_desktop vagrant up
  config.vm.provider :vmware_desktop do |vw|
    vw.memory = 6144
    vw.cpus   = 4
    vw.gui    = true
  end

  # Fix DNS and apt mirror before anything else
  config.vm.provision "shell", inline: <<-SHELL
    # Hardcode reliable DNS — libvirt dnsmasq + Google fallback
    chattr -i /etc/resolv.conf 2>/dev/null || true
    rm -f /etc/resolv.conf
    printf 'nameserver 192.168.122.1\nnameserver 8.8.8.8\n' > /etc/resolv.conf
    cat > /etc/apt/sources.list <<'EOF'
deb http://archive.ubuntu.com/ubuntu jammy main restricted universe multiverse
deb http://archive.ubuntu.com/ubuntu jammy-updates main restricted universe multiverse
deb http://archive.ubuntu.com/ubuntu jammy-backports main restricted universe multiverse
deb http://security.ubuntu.com/ubuntu jammy-security main restricted universe multiverse
EOF
  SHELL

  # Shared base provisioner
  config.vm.provision "shell", path: "../provision/base.sh"

  # Full GNOME desktop + SPICE guest agent for proper cursor and clipboard
  config.vm.provision "shell", inline: <<-SHELL
    export DEBIAN_FRONTEND=noninteractive
    apt-get install -y spice-vdagent ubuntu-desktop-minimal
    echo '/usr/sbin/gdm3' > /etc/X11/default-display-manager
    systemctl set-default graphical.target
  SHELL
  # wea — add apt repo and install
  config.vm.provision "shell", inline: <<-SHELL
    export DEBIAN_FRONTEND=noninteractive
    bash <(curl -fsSL https://oss-release-files.oss-accelerate.aliyuncs.com/wea/repos/apt/setup_prod_repo_apt.sh)
    apt-get install -y wea
  SHELL
end
