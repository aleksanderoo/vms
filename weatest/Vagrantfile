Vagrant.configure("2") do |config|
  config.vm.box = "generic/fedora43"

  config.vm.hostname = "weatest"

  # Network — uncomment to expose a port to the host
  # config.vm.network "forwarded_port", guest: 8080, host: 8080

  # Provider: Linux (libvirt)
  config.vm.provider :libvirt do |lv|
    lv.memory               = 6144
    lv.cpus                 = 4
    lv.graphics_type        = "spice"
    lv.video_type           = "qxl"
    lv.video_vram           = 65536  # KB — 64MB
    lv.machine_virtual_size = 40     # GB
  end

  # Provider: macOS (VMware Fusion / Workstation Pro)
  # VAGRANT_DEFAULT_PROVIDER=vmware_desktop vagrant up
  config.vm.provider :vmware_desktop do |vw|
    vw.memory = 6144
    vw.cpus   = 4
    vw.gui    = true
  end

  # Shared base provisioner
  config.vm.provision "shell", path: "../provision/base.sh"

  # Full GNOME desktop + SPICE guest agent for proper cursor and clipboard
  config.vm.provision "shell", inline: <<-SHELL
    dnf install -y @gnome-desktop gdm spice-vdagent firefox
    systemctl enable gdm
    systemctl set-default graphical.target
  SHELL
end
